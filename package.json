{
  "name": "openmanager",
  "version": "0.1.0",
  "description": "Local project workspace manager built for OpenClaw.",
  "type": "module",
  "private": false,
  "bin": {
    "openmanager": "./cli.js"
  },
  "scripts": {
    "build": "vite build && node scripts/sync-compat.mjs",
    "start": "npm run build && node server.js",
    "dev": "node backend/server.js",
    "dev:frontend": "vite",
    "regression": "node scripts/regression.mjs",
    "sync:compat": "node scripts/sync-compat.mjs",
    "smoke": "node scripts/smoke.mjs",
    "test": "npm run build && npm run smoke && npm run regression",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "workspace",
    "agent",
    "project-manager",
    "local-first"
  ],
  "license": "MIT",
  "devDependencies": {
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.5"
  }
}
