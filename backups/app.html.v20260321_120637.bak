<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Workspace Manager</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      color: #333;
    }
    
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }
    
    header {
      background: rgba(255,255,255,0.95);
      border-radius: 16px;
      padding: 24px 32px;
      margin-bottom: 24px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    header h1 {
      font-size: 28px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    header .subtitle {
      color: #666;
      font-size: 14px;
      margin-top: 4px;
    }
    
    .main-grid {
      display: grid;
      grid-template-columns: 300px 1fr 350px;
      gap: 24px;
    }
    
    .panel {
      background: rgba(255,255,255,0.95);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    
    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 2px solid #f0f0f0;
    }
    
    .panel-title {
      font-size: 18px;
      font-weight: 600;
      color: #333;
    }
    
    .btn {
      padding: 8px 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.2s;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }
    
    .btn-secondary {
      background: #f0f0f0;
      color: #333;
    }
    
    .btn-secondary:hover {
      background: #e0e0e0;
    }
    
    .btn-success {
      background: #10b981;
      color: white;
    }
    
    .btn-danger {
      background: #ef4444;
      color: white;
    }
    
    .project-list {
      list-style: none;
    }
    
    .project-item {
      padding: 16px;
      border-radius: 12px;
      margin-bottom: 12px;
      cursor: pointer;
      transition: all 0.2s;
      border: 2px solid transparent;
    }
    
    .project-item:hover {
      background: #f8f9fa;
    }
    
    .project-item.active {
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
      border-color: #667eea;
    }
    
    .project-name {
      font-weight: 600;
      font-size: 16px;
      margin-bottom: 4px;
    }
    
    .project-desc {
      color: #666;
      font-size: 13px;
    }
    
    .project-meta {
      display: flex;
      gap: 12px;
      margin-top: 8px;
      font-size: 12px;
      color: #999;
    }
    
    .session-list, .task-list {
      list-style: none;
    }
    
    .session-item, .task-item {
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #f8f9fa;
    }
    
    .session-item.active {
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
      border-left: 3px solid #667eea;
    }
    
    .task-checkbox {
      width: 20px;
      height: 20px;
      margin-right: 12px;
      cursor: pointer;
    }
    
    .task-content {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .task-text {
      flex: 1;
    }
    
    .task-text.completed {
      text-decoration: line-through;
      color: #999;
    }
    
    .task-actions {
      display: flex;
      gap: 8px;
      opacity: 0;
      transition: opacity 0.2s;
    }
    
    .task-item:hover .task-actions {
      opacity: 1;
    }
    
    .btn-icon {
      width: 32px;
      height: 32px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      transition: all 0.2s;
    }
    
    .btn-icon:hover {
      transform: scale(1.1);
    }
    
    .memory-viewer {
      background: #f8f9fa;
      border-radius: 8px;
      padding: 16px;
      max-height: 400px;
      overflow-y: auto;
      font-family: 'Monaco', 'Menlo', monospace;
      font-size: 13px;
      line-height: 1.6;
      white-space: pre-wrap;
    }
    
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0,0,0,0.5);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 1000;
    }
    
    .modal-overlay.active {
      display: flex;
    }
    
    .modal {
      background: white;
      border-radius: 16px;
      padding: 32px;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    
    .form-group {
      margin-bottom: 20px;
    }
    
    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 500;
      color: #555;
    }
    
    .form-group input, .form-group textarea {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      font-size: 14px;
      transition: border-color 0.2s;
    }
    
    .form-group input:focus, .form-group textarea:focus {
      outline: none;
      border-color: #667eea;
    }
    
    .modal-actions {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
    }
    
    .empty-state {
      text-align: center;
      padding: 40px 20px;
      color: #999;
    }
    
    .empty-state-icon {
      font-size: 48px;
      margin-bottom: 16px;
    }
    
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    
    .stat-card {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      padding: 16px;
      border-radius: 12px;
      text-align: center;
    }
    
    .stat-value {
      font-size: 24px;
      font-weight: 700;
    }
    
    .stat-label {
      font-size: 12px;
      opacity: 0.9;
      margin-top: 4px;
    }
    
    .tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 20px;
      border-bottom: 2px solid #e0e0e0;
      padding-bottom: 12px;
    }
    
    .tab {
      padding: 8px 16px;
      border-radius: 8px 8px 0 0;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s;
    }
    
    .tab.active {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
    }
    
    .tab:hover:not(.active) {
      background: #f0f0f0;
    }
    
    /* 对话界面样式 */
    .conversation-modal {
      max-width: 1200px;
      height: 85vh;
      display: flex;
      flex-direction: column;
      padding: 0;
      overflow: hidden;
    }
    
    .conversation-header {
      padding: 20px 24px;
      border-bottom: 1px solid #e0e0e0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #fafafa;
    }
    
    .conversation-header-title {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .conversation-body {
      flex: 1;
      overflow-y: auto;
      padding: 0;
      display: flex;
    }
    
    .conversation-messages {
      flex: 1;
      padding: 24px;
      overflow-y: auto;
    }
    
    .conversation-memory-panel {
      width: 350px;
      border-left: 1px solid #e0e0e0;
      background: #fafafa;
      display: flex;
      flex-direction: column;
    }
    
    .memory-panel-header {
      padding: 16px 20px;
      border-bottom: 1px solid #e0e0e0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: white;
    }
    
    .memory-panel-content {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
    }
    
    .memory-entry {
      background: white;
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 12px;
      border-left: 3px solid #667eea;
      font-size: 13px;
      line-height: 1.5;
    }
    
    .memory-entry .timestamp {
      font-size: 11px;
      color: #999;
      margin-bottom: 6px;
    }
    
    .memory-entry .content {
      color: #333;
    }
    
    .memory-actions {
      padding: 12px 20px;
      border-top: 1px solid #e0e0e0;
      background: white;
      display: flex;
      gap: 8px;
    }
    
    .message {
      margin-bottom: 20px;
      display: flex;
      gap: 12px;
    }
    
    .message.user {
      flex-direction: row-reverse;
    }
    
    .message-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    
    .message.user .message-avatar {
      background: linear-gradient(135deg, #667eea, #764ba2);
    }
    
    .message.assistant .message-avatar {
      background: #e0e0e0;
    }
    
    .message-content {
      max-width: 70%;
      padding: 12px 16px;
      border-radius: 12px;
      line-height: 1.5;
    }
    
    .message.user .message-content {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border-bottom-right-radius: 4px;
    }
    
    .message.assistant .message-content {
      background: #f0f0f0;
      color: #333;
      border-bottom-left-radius: 4px;
    }
    
    .conversation-input {
      padding: 16px 24px;
      border-top: 1px solid #e0e0e0;
      display: flex;
      gap: 12px;
      background: #fafafa;
    }
    
    .conversation-input input {
      flex: 1;
      padding: 12px 16px;
      border: 2px solid #e0e0e0;
      border-radius: 12px;
      font-size: 14px;
    }
    
    .conversation-input input:focus {
      outline: none;
      border-color: #667eea;
    }
    
    .memory-panel {
      background: #fafafa;
      border-radius: 12px;
      padding: 16px;
      margin-top: 20px;
      max-height: 300px;
      overflow-y: auto;
    }
    
    .memory-item {
      padding: 12px;
      background: white;
      border-radius: 8px;
      margin-bottom: 8px;
      font-size: 13px;
      border-left: 3px solid #667eea;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div style="display: flex; align-items: center; gap: 12px;">
        <div>
          <h1 style="margin: 0;">🚀 Project Workspace Manager</h1>
          <div style="font-size: 13px; color: #667eea; margin-top: 4px; font-weight: 500;">项目管理 · 简洁 · 快速</div>
        </div>
      </div>
      <div style="display: flex; gap: 12px; align-items: center;">
        <input type="text" id="searchInput" placeholder="🔍 搜索项目/任务..." style="padding: 8px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px; width: 200px;" oninput="handleSearch()">
        <button class="btn btn-primary" onclick="showCreateProjectModal()">+ 新建项目</button>
      </div>
    </header>
    
    <div class="main-grid">
      <!-- 左侧：项目列表 -->
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">📁 项目列表</span>
          <span class="subtitle" id="projectCount">0 个项目</span>
        </div>
        <ul class="project-list" id="projectList">
          <!-- 项目列表动态生成 -->
        </ul>
      </div>
      
      <!-- 中间：主内容区 -->
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title" id="currentProjectTitle">未选择项目</span>
        </div>
        
        <div id="noProjectSelected" class="empty-state">
          <div class="empty-state-icon">📭</div>
          <div>请从左侧选择一个项目</div>
          <div style="margin-top: 8px; font-size: 13px;">或创建新项目开始</div>
        </div>
        
        <div id="projectContent" style="display: none;">
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-value" id="sessionCount">0</div>
              <div class="stat-label">会话</div>
            </div>
            <div class="stat-card">
              <div class="stat-value" id="pendingTaskCount">0</div>
              <div class="stat-label">待办任务</div>
            </div>
            <div class="stat-card">
              <div class="stat-value" id="completedTaskCount">0</div>
              <div class="stat-label">已完成</div>
            </div>
          </div>
          
          <div class="tabs">
            <div class="tab active" onclick="switchTab('sessions')">💬 会话</div>
            <div class="tab" onclick="switchTab('tasks')">📋 任务</div>
            <div class="tab" onclick="switchTab('memory')">🧠 记忆</div>
          </div>
          
          <div id="sessionsTab">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
              <div>
                <span style="font-weight: 500; color: #666;">项目会话</span>
                <span style="font-size: 12px; color: #999; margin-left: 8px;" id="currentSessionLabel"></span>
              </div>
              <button class="btn btn-primary" onclick="showCreateSessionModal()">+ 新会话</button>
            </div>
            <ul class="session-list" id="sessionList"></ul>
          </div>
          
          <div id="tasksTab" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
              <span style="font-weight: 500; color: #666;">任务列表</span>
              <button class="btn btn-primary" onclick="showAddTaskModal()">+ 添加任务</button>
            </div>
            <ul class="task-list" id="taskList"></ul>
          </div>
          
          <div id="memoryTab" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
              <span style="font-weight: 500; color: #666;">共享记忆</span>
              <button class="btn btn-primary" onclick="editSharedMemory()">✏️ 编辑</button>
            </div>
            <div class="memory-viewer" id="sharedMemory">加载中...</div>
          </div>
        </div>
      </div>
      
      <!-- 右侧：项目信息 -->
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">ℹ️ 项目信息</span>
        </div>
        <div id="projectInfo" class="empty-state">
          <div class="empty-state-icon">ℹ️</div>
          <div>选择项目查看详情</div>
        </div>
        <div id="projectInfoContent" style="display: none;">
          <div style="margin-bottom: 16px;">
            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">项目名称</div>
            <div style="font-weight: 500;" id="infoName"></div>
          </div>
          <div style="margin-bottom: 16px;">
            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">描述</div>
            <div style="color: #666;" id="infoDesc"></div>
          </div>
          <div style="margin-bottom: 16px;">
            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">创建时间</div>
            <div style="color: #666;" id="infoCreatedAt"></div>
          </div>
          <div style="margin-bottom: 16px;">
            <div style="font-size: 12px; color: #999; margin-bottom: 4px;">路径</div>
            <div style="font-size: 11px; color: #999; word-break: break-all;" id="infoPath"></div>
          </div>
          <div style="border-top: 1px solid #e0e0e0; padding-top: 16px;">
            <button class="btn btn-secondary" style="width: 100%; margin-bottom: 8px;" onclick="openProjectFolder()">📂 打开文件夹</button>
            <button class="btn btn-secondary" style="width: 100%; margin-bottom: 8px;" onclick="exportProject()">📤 导出项目</button>
            <button class="btn btn-primary" style="width: 100%; margin-bottom: 8px;" onclick="renameCurrentProject()">✏️ 重命名</button>
            <button class="btn btn-danger" style="width: 100%;" onclick="deleteCurrentProject()">🗑️ 删除项目</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- 创建项目弹窗 -->
  <div class="modal-overlay" id="createProjectModal">
    <div class="modal">
      <h2>📁 创建新项目</h2>
      <div class="form-group">
        <label>项目名称</label>
        <input type="text" id="newProjectName" placeholder="例如：dashboard-project">
      </div>
      <div class="form-group">
        <label>项目描述</label>
        <input type="text" id="newProjectDesc" placeholder="项目简介...">
      </div>
      <div class="modal-actions">
        <button class="btn btn-secondary" onclick="hideModal('createProjectModal')">取消</button>
        <button class="btn btn-primary" onclick="createProject()">创建</button>
      </div>
    </div>
  </div>
  
  <!-- 创建会话弹窗 -->
  <div class="modal-overlay" id="createSessionModal">
    <div class="modal">
      <h2>💬 创建新会话</h2>
      <div class="form-group">
        <label>会话名称</label>
        <input type="text" id="newSessionName" placeholder="例如：数据收集">
      </div>
      <div class="modal-actions">
        <button class="btn btn-secondary" onclick="hideModal('createSessionModal')">取消</button>
        <button class="btn btn-primary" onclick="createSession()">创建</button>
      </div>
    </div>
  </div>
  
  <!-- 添加任务弹窗 -->
  <div class="modal-overlay" id="addTaskModal">
    <div class="modal">
      <h2>📋 添加任务</h2>
      <div class="form-group">
        <label>任务描述</label>
        <textarea id="newTaskDesc" rows="3" placeholder="任务内容..."></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn btn-secondary" onclick="hideModal('addTaskModal')">取消</button>
        <button class="btn btn-primary" onclick="addTask()">添加</button>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = 'http://localhost:3456';
    
    let projects = [];
    let currentProject = null;
    let currentTab = 'sessions';
    let searchQuery = '';
    
    // 初始化
    async function init() {
      await loadProjects();
      renderProjectList();
    }
    
    // 加载项目
    async function loadProjects() {
      try {
        const response = await fetch(`${API_BASE}/api/projects`);
        const data = await response.json();
        projects = data.projects || [];
        if (data.currentProject) {
          currentProject = data.currentProject;
        }
      } catch (e) {
        console.error('加载项目失败:', e);
        alert('无法连接服务器，请确保 server.js 正在运行\n\n启动命令：node server.js');
        projects = [];
      }
      updateProjectCount();
    }
    
    // 更新项目计数
    function updateProjectCount() {
      document.getElementById('projectCount').textContent = `${projects.length} 个项目`;
    }
    
    // 渲染项目列表
    function renderProjectList() {
      const list = document.getElementById('projectList');
      
      if (projects.length === 0) {
        list.innerHTML = `
          <li class="empty-state">
            <div class="empty-state-icon">📭</div>
            <div>暂无项目</div>
            <button class="btn btn-primary" style="margin-top: 12px;" onclick="showCreateProjectModal()">创建第一个项目</button>
          </li>
        `;
        return;
      }
      
      // 搜索过滤
      let filtered = projects;
      if (searchQuery) {
        filtered = projects.filter(p => 
          p.name.toLowerCase().includes(searchQuery) ||
          (p.description && p.description.toLowerCase().includes(searchQuery))
        );
      }
      
      if (filtered.length === 0 && searchQuery) {
        list.innerHTML = `
          <li class="empty-state">
            <div class="empty-state-icon">🔍</div>
            <div>未找到匹配的项目</div>
            <div style="font-size: 12px; color: #999; margin-top: 8px;">搜索："${searchQuery}"</div>
          </li>
        `;
        return;
      }
      
      list.innerHTML = filtered.map(p => `
        <li class="project-item ${currentProject === p.name ? 'active' : ''}" onclick="selectProject('${p.name}')">
          <div class="project-name">${p.name}</div>
          <div class="project-desc">${p.description || '无描述'}</div>
          <div class="project-meta">
            <span>💬 ${p.sessions || 0} 会话</span>
            <span>📋 ${p.tasks?.pending || 0} 待办</span>
          </div>
        </li>
      `).join('');
    }
    
    // 搜索功能
    function handleSearch() {
      searchQuery = document.getElementById('searchInput').value.toLowerCase();
      renderProjectList();
    }
    
    // 选择项目
    async function selectProject(name) {
      try {
        await fetch(`${API_BASE}/api/projects/${name}/switch`, { method: 'POST' });
        currentProject = name;
        document.getElementById('noProjectSelected').style.display = 'none';
        document.getElementById('projectContent').style.display = 'block';
        document.getElementById('currentProjectTitle').textContent = `📁 ${name}`;
        
        renderProjectList();
        await loadProjectDetails();
      } catch (e) {
        alert('切换项目失败：' + e.message);
      }
    }
    
    // 加载项目详情
    async function loadProjectDetails() {
      if (!currentProject) return;
      
      try {
        const [sessionsRes, tasksRes, memoryRes, projectRes] = await Promise.all([
          fetch(`${API_BASE}/api/projects/${currentProject}/sessions`),
          fetch(`${API_BASE}/api/projects/${currentProject}/tasks`),
          fetch(`${API_BASE}/api/projects/${currentProject}/memory/shared`),
          fetch(`${API_BASE}/api/projects/${currentProject}`)
        ]);
        
        const sessionsData = await sessionsRes.json();
        const tasksData = await tasksRes.json();
        const memoryData = await memoryRes.json();
        const projectData = await projectRes.json();
        
        renderSessions(sessionsData.sessions || [], sessionsData.currentSession);
        renderTasks(tasksData.tasks || []);
        updateStats(sessionsData.sessions || [], tasksData.tasks || []);
        renderMemory(memoryData.content || '');
        renderProjectInfo(projectData);
      } catch (e) {
        console.error('加载项目详情失败:', e);
      }
    }
    
    // 渲染会话列表
    function renderSessions(sessions, currentSession) {
      const list = document.getElementById('sessionList');
      const currentSessionLabel = document.getElementById('currentSessionLabel');
      
      if (sessions.length === 0) {
        list.innerHTML = `
          <li class="empty-state">
            <div class="empty-state-icon">💬</div>
            <div>暂无会话</div>
            <div style="font-size: 12px; color: #999; margin-top: 8px;">点击上方"+ 新会话"按钮创建</div>
          </li>
        `;
        currentSessionLabel.textContent = '';
        return;
      }
      
      currentSessionLabel.textContent = `· 当前：${currentSession || '无'}`;
      
      list.innerHTML = sessions.map(s => {
        const isActive = s.id === currentSession;
        return `
        <li class="session-item ${isActive ? 'active' : ''}">
          <div style="flex: 1;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 16px;">${isActive ? '💬' : '🗨️'}</span>
              <div>
                <div style="display: flex; align-items: center; gap: 6px;">
                  <span style="font-weight: 500;">${s.name}</span>
                  <button class="btn-icon btn-secondary" onclick="event.stopPropagation(); renameSession('${s.id}')" title="重命名" style="width: 24px; height: 24px; font-size: 12px;">✏️</button>
                </div>
                <div style="font-size: 11px; color: #999;">${s.id}</div>
              </div>
            </div>
          </div>
          <div style="display: flex; gap: 6px;">
            ${!isActive ? `<button class="btn-icon btn-success" onclick="switchSession('${s.id}')" title="切换">✓</button>` : ''}
            <button class="btn-icon btn-primary" onclick="openConversation('${s.id}')" title="打开对话" style="background: linear-gradient(135deg, #667eea, #764ba2); color: white;">💬</button>
            <button class="btn-icon btn-danger" onclick="deleteSession('${s.id}')" title="删除">🗑️</button>
          </div>
        </li>
      `}).join('');
    }
    
    // 渲染任务列表
    function renderTasks(tasks) {
      const list = document.getElementById('taskList');
      list.innerHTML = tasks.map(t => `
        <li class="task-item">
          <div class="task-content">
            <input type="checkbox" class="task-checkbox" ${t.completed ? 'checked' : ''} onchange="toggleTask(${t.id})">
            <span class="task-text ${t.completed ? 'completed' : ''}">${t.description}</span>
          </div>
          <div class="task-actions">
            <button class="btn-icon btn-danger" onclick="deleteTask(${t.id})" title="删除">🗑️</button>
          </div>
        </li>
      `).join('');
    }
    
    // 更新统计
    function updateStats(sessions, tasks) {
      document.getElementById('sessionCount').textContent = sessions.length;
      document.getElementById('pendingTaskCount').textContent = tasks.filter(t => !t.completed).length;
      document.getElementById('completedTaskCount').textContent = tasks.filter(t => t.completed).length;
    }
    
    // 渲染记忆
    function renderMemory(content) {
      document.getElementById('sharedMemory').textContent = content || '暂无内容';
    }
    
    // 渲染项目信息
    function renderProjectInfo(project) {
      document.getElementById('projectInfo').style.display = 'none';
      document.getElementById('projectInfoContent').style.display = 'block';
      
      document.getElementById('infoName').textContent = project.name;
      document.getElementById('infoDesc').textContent = project.description || '无描述';
      document.getElementById('infoCreatedAt').textContent = new Date(project.createdAt).toLocaleString('zh-CN');
      document.getElementById('infoPath').textContent = project.path;
    }
    
    // 切换标签页
    function switchTab(tab) {
      currentTab = tab;
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      event.target.classList.add('active');
      
      document.getElementById('sessionsTab').style.display = tab === 'sessions' ? 'block' : 'none';
      document.getElementById('tasksTab').style.display = tab === 'tasks' ? 'block' : 'none';
      document.getElementById('memoryTab').style.display = tab === 'memory' ? 'block' : 'none';
    }
    
    // 显示/隐藏弹窗
    function showCreateProjectModal() {
      document.getElementById('createProjectModal').classList.add('active');
    }
    
    function showCreateSessionModal() {
      document.getElementById('createSessionModal').classList.add('active');
    }
    
    function showAddTaskModal() {
      document.getElementById('addTaskModal').classList.add('active');
    }
    
    function hideModal(id) {
      document.getElementById(id).classList.remove('active');
    }
    
    // 创建项目
    async function createProject() {
      const name = document.getElementById('newProjectName').value.trim();
      const desc = document.getElementById('newProjectDesc').value.trim();
      
      if (!name) {
        alert('请输入项目名称');
        return;
      }
      
      try {
        const res = await fetch(`${API_BASE}/api/projects`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, description: desc })
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        hideModal('createProjectModal');
        document.getElementById('newProjectName').value = '';
        document.getElementById('newProjectDesc').value = '';
        
        await loadProjects();
        renderProjectList();
        selectProject(name);
      } catch (e) {
        alert('创建项目失败：' + e.message);
      }
    }
    
    // 创建会话
    async function createSession() {
      const sessionName = document.getElementById('newSessionName').value.trim();
      
      if (!currentProject) {
        alert('请先选择项目');
        return;
      }
      
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/sessions`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionName })
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        hideModal('createSessionModal');
        document.getElementById('newSessionName').value = '';
        
        await loadProjectDetails();
      } catch (e) {
        alert('创建会话失败：' + e.message);
      }
    }
    
    // 添加任务
    async function addTask() {
      const description = document.getElementById('newTaskDesc').value.trim();
      
      if (!currentProject) {
        alert('请先选择项目');
        return;
      }
      
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/tasks`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ description })
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        hideModal('addTaskModal');
        document.getElementById('newTaskDesc').value = '';
        
        await loadProjectDetails();
      } catch (e) {
        alert('添加任务失败：' + e.message);
      }
    }
    
    // 切换会话
    async function switchSession(sessionId) {
      try {
        await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/switch`, {
          method: 'POST'
        });
        await loadProjectDetails();
      } catch (e) {
        alert('切换会话失败：' + e.message);
      }
    }
    
    // 打开对话界面
    async function openConversation(sessionId) {
      // 切换到该会话
      await switchSession(sessionId);
      
      // 获取会话信息
      const sessionName = document.querySelector(`.session-item.active .btn-icon[onclick*="renameSession"]`)?.previousSibling?.textContent?.trim() || sessionId;
      
      // 创建对话界面
      const overlay = document.createElement('div');
      overlay.className = 'modal-overlay active';
      overlay.id = 'conversationModal';
      overlay.innerHTML = `
        <div class="modal conversation-modal">
          <div class="conversation-header">
            <div class="conversation-header-title">
              <h2 style="margin: 0;">💬 ${sessionName}</h2>
              <span style="font-size: 12px; color: #999; margin-left: 12px;">${currentProject}</span>
            </div>
            <button class="btn btn-secondary" onclick="document.getElementById('conversationModal').remove()">✕ 关闭</button>
          </div>
          
          <div class="conversation-body">
            <div class="conversation-messages" id="conversationMessages">
              <div class="message assistant">
                <div class="message-avatar">🤖</div>
                <div class="message-content">
                  你好！我是你的 AI 助手 🚀<br><br>
                  这里是 <strong>${sessionName}</strong> 对话空间。<br>
                  我可以帮你记录想法、整理思路、总结对话。<br><br>
                  💡 提示：点击右侧 <strong>🤖 压缩</strong> 可以用 AI 智能总结对话内容
                </div>
              </div>
            </div>
            
            <div class="conversation-memory-panel">
              <div class="memory-panel-header">
                <span style="font-weight: 600; color: #667eea;">🧠 对话记忆</span>
                <div style="display: flex; gap: 4px;">
                  <button class="btn btn-secondary" onclick="showLogsModal('${sessionId}')" title="查看日志" style="padding: 4px 8px; font-size: 12px;">📜</button>
                  <button class="btn btn-secondary" onclick="copyMemory()" style="padding: 4px 8px; font-size: 12px;">📋</button>
                </div>
              </div>
              <div class="memory-panel-content" id="memoryPanelContent">
                <div style="color: #999; font-size: 13px; text-align: center; padding: 20px;">
                  对话记忆将自动记录在这里<br><br>
                  点击"🤖 压缩"可用 AI 智能总结
                </div>
              </div>
              <div class="memory-actions">
                <button class="btn btn-secondary" style="flex: 1;" onclick="copyMemory()">📋 复制全部</button>
                <button class="btn btn-primary" style="flex: 1;" onclick="compressMemory('${sessionId}')">🤖 AI 压缩</button>
              </div>
            </div>
          </div>
          
          <div class="conversation-input">
            <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
              <input type="file" id="fileInput" accept="image/*,audio/*" style="display: none;" onchange="handleFileSelect('${sessionId}', this)">
              <button class="btn btn-secondary" onclick="document.getElementById('fileInput').click()" title="上传图片/语音" style="padding: 6px 10px; font-size: 14px;">📎</button>
              <div id="filePreview_${sessionId}" style="flex: 1; display: none; align-items: center; gap: 8px; background: #f0f0f0; padding: 8px; border-radius: 8px;">
                <span id="fileName_${sessionId}" style="font-size: 13px; color: #666; flex: 1;"></span>
                <button class="btn btn-secondary" onclick="clearFile('${sessionId}')" style="padding: 2px 6px; font-size: 12px;">✕</button>
              </div>
            </div>
            <div style="display: flex; gap: 8px;">
              <input type="text" id="messageInput" placeholder="输入消息... (按 Enter 发送，支持图片/语音上传)" onkeypress="if(event.key==='Enter')sendMessage('${sessionId}')" style="flex: 1;">
              <button class="btn btn-primary" onclick="sendMessage('${sessionId}')">发送</button>
            </div>
          </div>
        </div>
      `;
      document.body.appendChild(overlay);
      
      // 加载对话记忆
      loadConversationMemory(sessionId);
    }
    
    // 发送消息（支持文件上传）
    async function sendMessage(sessionId) {
      const input = document.getElementById('messageInput');
      const message = input.value.trim();
      const file = selectedFiles[sessionId];
      
      if (!message && !file) return;
      
      let attachments = [];
      let fullMessage = message;
      
      // 处理文件上传
      if (file) {
        try {
          const uploadResult = await uploadFile(sessionId, file);
          attachments.push({
            url: `${API_BASE}${uploadResult.url}`,
            filename: uploadResult.filename,
            mimeType: uploadResult.mimeType
          });
          
          // 在消息中添加文件信息
          if (file.type.startsWith('image/')) {
            fullMessage = message ? `[图片：${file.name}]\n${message}` : `[图片：${file.name}]`;
          } else if (file.type.startsWith('audio/')) {
            fullMessage = message ? `[语音：${file.name}]\n${message}` : `[语音：${file.name}]`;
          }
          
          // 清除已上传的文件
          clearFile(sessionId);
        } catch (e) {
          addMessage(`文件上传失败：${e.message}`, 'error');
          return;
        }
      }
      
      // 添加用户消息（带附件）
      addMessage(fullMessage, 'user', attachments);
      input.value = '';
      
      // 记录原始对话到记忆（用于 AI 压缩）
      await appendToMemoryRaw(sessionId, { type: 'user', text: fullMessage, time: new Date().toISOString() });
      
      // 显示思考中状态
      const thinkingId = addThinkingMessage();
      
      // 调用 OpenClaw API
      try {
        const res = await fetch(`${API_BASE}/api/openclaw/chat`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            project: currentProject,
            session: sessionId,
            message: fullMessage
          })
        });
        
        const data = await res.json();
        
        // 移除思考中消息
        removeThinkingMessage(thinkingId);
        
        if (data.connected === false) {
          // 错误情况
          addMessage(data.response, 'error');
          await appendToMemoryRaw(sessionId, { type: 'error', text: data.response, time: new Date().toISOString() });
        } else {
          // 成功响应
          const response = data.response || 'OpenClaw 已处理';
          
          // 显示 tool calls
          if (data.toolCalls && data.toolCalls.length > 0) {
            showToolCalls(data.toolCalls);
            // 等待一下让用户看到 tool calls
            await new Promise(resolve => setTimeout(resolve, 800));
          }
          
          addMessage(response, 'assistant');
          await appendToMemoryRaw(sessionId, { type: 'assistant', text: response, time: new Date().toISOString() });
          
          // 如果有 meta 信息（思考过程），显示在记忆面板
          if (data.meta) {
            await appendToMemoryRaw(sessionId, { 
              type: 'meta', 
              text: `⏱️ 耗时：${(data.meta.durationMs / 1000).toFixed(1)}s | 🤖 模型：${data.meta.agentMeta?.model || 'unknown'}`, 
              time: new Date().toISOString() 
            });
          }
          
          // 如果有 tool calls，也记录到记忆
          if (data.toolCalls && data.toolCalls.length > 0) {
            await appendToMemoryRaw(sessionId, { 
              type: 'tools', 
              text: `🔧 调用工具：${data.toolCalls.map(t => t.name).join(', ')}`, 
              time: new Date().toISOString() 
            });
          }
        }
        
        // 更新记忆面板显示
        renderMemoryPanel(sessionId);
      } catch (e) {
        // 移除思考中消息
        removeThinkingMessage(thinkingId);
        
        const errorMsg = `调用 OpenClaw 失败：${e.message}`;
        addMessage(errorMsg, 'error');
        await appendToMemoryRaw(sessionId, { type: 'error', text: errorMsg, time: new Date().toISOString() });
        renderMemoryPanel(sessionId);
      }
    }
    
    // 添加思考中消息
    let thinkingMessageId = null;
    let thinkingStartTime = null;
    let thinkingTimerInterval = null;
    
    function addThinkingMessage() {
      const messagesDiv = document.getElementById('conversationMessages');
      const thinkingId = 'thinking-' + Date.now();
      thinkingMessageId = thinkingId;
      thinkingStartTime = Date.now();
      
      const messageDiv = document.createElement('div');
      messageDiv.className = 'message assistant';
      messageDiv.id = thinkingId;
      messageDiv.innerHTML = `
        <div class="message-avatar">🤖</div>
        <div class="message-content">
          <div style="display: flex; align-items: center; gap: 8px; color: #667eea;">
            <div style="width: 16px; height: 16px; border: 2px solid #667eea; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
            <span>思考中...</span>
            <span id="thinkingTimer" style="font-size: 12px; color: #999; margin-left: 8px;">0.0s</span>
          </div>
          <div id="toolCallsContainer" style="margin-top: 8px; display: none;"></div>
          <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
        </div>
      `;
      messagesDiv.appendChild(messageDiv);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
      
      // 启动计时器
      thinkingTimerInterval = setInterval(() => {
        const elapsed = ((Date.now() - thinkingStartTime) / 1000).toFixed(1);
        const timerEl = document.getElementById('thinkingTimer');
        if (timerEl) {
          timerEl.textContent = `${elapsed}s`;
        }
      }, 100);
      
      return thinkingId;
    }
    
    // 显示 Tool 调用
    function showToolCalls(toolCalls) {
      const container = document.getElementById('toolCallsContainer');
      if (!container || !toolCalls || toolCalls.length === 0) return;
      
      container.style.display = 'block';
      container.innerHTML = toolCalls.map(tool => `
        <div style="font-size: 11px; color: #10b981; background: rgba(16,185,129,0.1); padding: 4px 8px; border-radius: 4px; margin-top: 4px; display: inline-block; margin-right: 4px;">
          🔧 ${tool.name}${tool.args && Object.keys(tool.args).length > 0 ? '(' + Object.keys(tool.args).slice(0, 2).join(', ') + ')' : ''}
        </div>
      `).join('');
    }
    
    function removeThinkingMessage(thinkingId) {
      // 停止计时器
      if (thinkingTimerInterval) {
        clearInterval(thinkingTimerInterval);
        thinkingTimerInterval = null;
      }
      
      const element = document.getElementById(thinkingId);
      if (element) {
        element.remove();
      }
      thinkingMessageId = null;
      thinkingStartTime = null;
    }
    
    // 文件上传相关
    let selectedFiles = {};
    
    function handleFileSelect(sessionId, input) {
      const file = input.files[0];
      if (!file) return;
      
      selectedFiles[sessionId] = file;
      
      const preview = document.getElementById(`filePreview_${sessionId}`);
      const fileName = document.getElementById(`fileName_${sessionId}`);
      
      preview.style.display = 'flex';
      fileName.textContent = `📎 ${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
    }
    
    function clearFile(sessionId) {
      selectedFiles[sessionId] = null;
      const input = document.getElementById('fileInput');
      if (input) input.value = '';
      
      const preview = document.getElementById(`filePreview_${sessionId}`);
      if (preview) preview.style.display = 'none';
    }
    
    async function uploadFile(sessionId, file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = async (e) => {
          try {
            const res = await fetch(`${API_BASE}/api/upload`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                filename: file.name,
                content: e.target.result,
                mimeType: file.type,
                project: currentProject,
                session: sessionId
              })
            });
            
            const data = await res.json();
            if (data.success) {
              resolve(data);
            } else {
              reject(new Error(data.error || '上传失败'));
            }
          } catch (err) {
            reject(err);
          }
        };
        reader.onerror = () => reject(new Error('文件读取失败'));
        reader.readAsDataURL(file);
      });
    }
    
    // 添加消息到界面
    function addMessage(text, type, attachments = []) {
      const messagesDiv = document.getElementById('conversationMessages');
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${type}`;
      
      let attachmentsHtml = '';
      if (attachments.length > 0) {
        attachmentsHtml = `<div style="margin-bottom: 8px; display: flex; flex-wrap: wrap; gap: 8px;">${attachments.map(att => {
          if (att.mimeType?.startsWith('image/')) {
            return `<img src="${att.url}" style="max-width: 200px; max-height: 200px; border-radius: 8px; cursor: pointer;" onclick="window.open('${att.url}')">`;
          } else if (att.mimeType?.startsWith('audio/')) {
            return `<audio controls src="${att.url}" style="max-width: 300px;"></audio>`;
          } else {
            return `<a href="${att.url}" target="_blank" style="padding: 8px 12px; background: #667eea; color: white; border-radius: 6px; text-decoration: none; font-size: 13px;">📄 ${att.filename}</a>`;
          }
        }).join('')}</div>`;
      }
      
      messageDiv.innerHTML = `
        <div class="message-avatar">${type === 'user' ? '👤' : type === 'error' ? '❌' : '🤖'}</div>
        <div class="message-content">
          ${attachmentsHtml}
          <div style="white-space: pre-wrap;">${text}</div>
        </div>
      `;
      messagesDiv.appendChild(messageDiv);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
    
    // 加载对话记忆
    async function loadConversationMemory(sessionId) {
      await renderMemoryPanel(sessionId);
    }
    
    // 追加原始对话到记忆
    async function appendToMemoryRaw(sessionId, entry) {
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/memory`);
        const data = await res.json();
        
        let rawEntries = [];
        if (data.content) {
          try {
            rawEntries = JSON.parse(data.content);
          } catch (e) {
            rawEntries = [];
          }
        }
        
        rawEntries.push(entry);
        
        await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/memory`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: JSON.stringify(rawEntries, null, 2) })
        });
      } catch (e) {
        console.error('更新记忆失败:', e);
      }
    }
    
    // 渲染记忆面板
    async function renderMemoryPanel(sessionId) {
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/memory`);
        const data = await res.json();
        
        const panelContent = document.getElementById('memoryPanelContent');
        
        if (!data.content || data.content === '[]') {
          panelContent.innerHTML = `
            <div style="color: #999; font-size: 13px; text-align: center; padding: 20px;">
              暂无对话记忆
            </div>
          `;
          return;
        }
        
        let entries = [];
        try {
          entries = JSON.parse(data.content);
        } catch (e) {
          entries = [];
        }
        
        if (entries.length === 0) {
          panelContent.innerHTML = `
            <div style="color: #999; font-size: 13px; text-align: center; padding: 20px;">
              暂无对话记忆
            </div>
          `;
          return;
        }
        
        // 分离不同类型的记忆
        const uncompressedEntries = entries.filter(e => e.type !== 'compressed_summary' && e.type !== 'tools' && e.type !== 'meta');
        const compressedEntries = entries.filter(e => e.type === 'compressed_summary');
        const toolEntries = entries.filter(e => e.type === 'tools');
        const metaEntries = entries.filter(e => e.type === 'meta');
        
        let html = '';
        
        // 渲染未压缩的记忆（新记忆）
        if (uncompressedEntries.length > 0) {
          html += `
            <div style="margin-bottom: 16px;">
              <div style="font-size: 12px; font-weight: 600; color: #667eea; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                <span style="width: 8px; height: 8px; background: #667eea; border-radius: 50%;"></span>
                对话记录 (${uncompressedEntries.length}条)
              </div>
              ${uncompressedEntries.map(entry => {
                const time = new Date(entry.time).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
                const icon = entry.type === 'user' ? '👤' : entry.type === 'assistant' ? '🤖' : entry.type === 'error' ? '❌' : '⚠️';
                const color = entry.type === 'user' ? '#667eea' : entry.type === 'assistant' ? '#10b981' : entry.type === 'error' ? '#ef4444' : '#f59e0b';
                
                return `
                  <div class="memory-entry" style="margin-bottom: 8px;">
                    <div class="timestamp">${icon} ${time}</div>
                    <div class="content" style="border-left: 3px solid ${color}; padding-left: 8px;">${entry.text}</div>
                  </div>
                `;
              }).join('')}
            </div>
          `;
        }
        
        // 渲染工具调用记录
        if (toolEntries.length > 0) {
          html += `
            <div style="margin-bottom: 16px;">
              <div style="font-size: 12px; font-weight: 600; color: #10b981; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                <span style="width: 8px; height: 8px; background: #10b981; border-radius: 50%;"></span>
                工具调用 (${toolEntries.length}次)
              </div>
              ${toolEntries.map(entry => {
                const time = new Date(entry.time).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
                return `
                  <div class="memory-entry" style="margin-bottom: 8px; border-left-color: #10b981; background: #f0fdf4;">
                    <div class="timestamp" style="color: #10b981;">🔧 ${time}</div>
                    <div class="content" style="border-left: 3px solid #10b981; padding-left: 8px; font-size: 12px;">${entry.text}</div>
                  </div>
                `;
              }).join('')}
            </div>
          `;
        }
        
        // 渲染元信息（耗时等）
        if (metaEntries.length > 0) {
          html += `
            <div style="margin-bottom: 16px;">
              <div style="font-size: 12px; font-weight: 600; color: #6b7280; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                <span style="width: 8px; height: 8px; background: #6b7280; border-radius: 50%;"></span>
                执行信息
              </div>
              ${metaEntries.map(entry => {
                const time = new Date(entry.time).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
                return `
                  <div class="memory-entry" style="margin-bottom: 8px; border-left-color: #6b7280; background: #f9fafb;">
                    <div class="timestamp" style="color: #6b7280;">⚙️ ${time}</div>
                    <div class="content" style="border-left: 3px solid #6b7280; padding-left: 8px; font-size: 12px;">${entry.text}</div>
                  </div>
                `;
              }).join('')}
            </div>
          `;
        }
        
        // 渲染已压缩的记忆（压缩历史）
        if (compressedEntries.length > 0) {
          html += `
            <div style="border-top: 2px dashed #e0e0e0; padding-top: 16px;">
              <div style="font-size: 12px; font-weight: 600; color: #10b981; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                <span style="width: 8px; height: 8px; background: #10b981; border-radius: 50%;"></span>
                压缩历史 (${compressedEntries.length}次压缩)
              </div>
              ${compressedEntries.map((entry, idx) => {
                const time = new Date(entry.time).toLocaleString('zh-CN', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' });
                const fromInfo = entry.compressedFrom ? `（压缩${entry.compressedFrom.count}条记录）` : '';
                
                return `
                  <div class="memory-entry" style="margin-bottom: 8px; border-left-color: #10b981; background: #f0fdf4;">
                    <div class="timestamp" style="color: #10b981;">🗜️ 第${idx + 1}次压缩 · ${time} ${fromInfo}</div>
                    <div class="content" style="border-left: 3px solid #10b981; padding-left: 8px; font-size: 12px;">${entry.text}</div>
                  </div>
                `;
              }).join('')}
            </div>
          `;
        }
        
        panelContent.innerHTML = html;
      } catch (e) {
        console.error('加载记忆失败:', e);
      }
    }
    
    // AI 压缩记忆
    async function compressMemory(sessionId) {
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/memory`);
        const data = await res.json();
        
        if (!data.content || data.content === '[]') {
          alert('暂无记忆可压缩');
          return;
        }
        
        let entries = [];
        try {
          entries = JSON.parse(data.content);
        } catch (e) {
          alert('记忆格式错误');
          return;
        }
        
        // 分离未压缩的记忆和已压缩的记忆
        const uncompressedEntries = entries.filter(e => e.type !== 'compressed_summary');
        const compressedEntries = entries.filter(e => e.type === 'compressed_summary');
        
        if (uncompressedEntries.length === 0) {
          alert('没有新的未压缩记忆。所有记忆已被压缩过。');
          return;
        }
        
        // 调用 AI 压缩
        const compressRes = await fetch(`${API_BASE}/api/openclaw/compress`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            project: currentProject,
            session: sessionId,
            entries: uncompressedEntries
          })
        });
        
        const compressData = await compressRes.json();
        
        if (compressData.error) {
          throw new Error(compressData.error);
        }
        
        // 将新的压缩内容追加到已压缩区域
        const newCompressedEntry = {
          type: 'compressed_summary',
          text: compressData.summary,
          time: new Date().toISOString(),
          compressedFrom: {
            start: uncompressedEntries[0]?.time,
            end: uncompressedEntries[uncompressedEntries.length - 1]?.time,
            count: uncompressedEntries.length
          }
        };
        
        // 保留已压缩的记忆，追加新的压缩内容
        const updatedEntries = [...compressedEntries, newCompressedEntry];
        
        // 保存更新后的记忆
        await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/memory`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: JSON.stringify(updatedEntries, null, 2) })
        });
        
        // 重新渲染
        await renderMemoryPanel(sessionId);
        alert(`记忆已压缩！已压缩 ${uncompressedEntries.length} 条记录，当前共有 ${updatedEntries.length} 条压缩记录。`);
      } catch (e) {
        alert('压缩失败：' + e.message);
      }
    }
    
    // 复制记忆
    function copyMemory() {
      const panelContent = document.getElementById('memoryPanelContent');
      const text = panelContent.textContent;
      navigator.clipboard.writeText(text).then(() => {
        alert('记忆已复制');
      }).catch(err => {
        alert('复制失败：' + err);
      });
    }
    
    // 查看日志
    async function showLogsModal(sessionId) {
      const overlay = document.createElement('div');
      overlay.className = 'modal-overlay active';
      overlay.id = 'logsModal';
      overlay.innerHTML = `
        <div class="modal" style="max-width: 800px; height: 80vh; display: flex; flex-direction: column;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <h2 style="margin: 0;">📜 OpenClaw 日志</h2>
            <button class="btn btn-secondary" onclick="document.getElementById('logsModal').remove()">✕ 关闭</button>
          </div>
          <div style="flex: 1; overflow-y: auto; background: #1e1e1e; border-radius: 8px; padding: 16px; font-family: 'Monaco', 'Menlo', monospace; font-size: 12px; color: #d4d4d4;" id="logsContent">
            <div style="text-align: center; padding: 40px; color: #666;">
              <div style="width: 24px; height: 24px; border: 3px solid #667eea; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
              加载日志中...
            </div>
          </div>
          <div style="margin-top: 16px; display: flex; gap: 8px; justify-content: flex-end;">
            <button class="btn btn-secondary" onclick="refreshLogs()">🔄 刷新</button>
            <button class="btn btn-primary" onclick="copyLogs()">📋 复制日志</button>
          </div>
        </div>
      `;
      document.body.appendChild(overlay);
      
      // 加载日志
      await loadLogs();
    }
    
    async function loadLogs() {
      try {
        const res = await fetch(`${API_BASE}/api/openclaw/logs`);
        const data = await res.json();
        
        const logsContent = document.getElementById('logsContent');
        
        if (data.error) {
          logsContent.innerHTML = `<div style="color: #ef4444; padding: 20px;">加载日志失败：${data.error}</div>`;
          return;
        }
        
        if (data.logs.length === 0) {
          logsContent.innerHTML = `<div style="color: #666; padding: 20px; text-align: center;">暂无日志</div>`;
          return;
        }
        
        logsContent.innerHTML = data.logs.map(log => {
          const levelColor = log.level === 'ERROR' ? '#ef4444' : log.level === 'WARN' ? '#f59e0b' : log.level === 'DEBUG' ? '#6b7280' : '#10b981';
          const time = log.time ? new Date(log.time).toLocaleTimeString('zh-CN') : '';
          
          return `
            <div style="margin-bottom: 8px; padding: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; border-left: 3px solid ${levelColor};">
              <div style="display: flex; gap: 12px; align-items: baseline;">
                <span style="color: #6b7280; font-size: 11px;">${time}</span>
                <span style="color: ${levelColor}; font-weight: 600; font-size: 11px; min-width: 50px;">${log.level}</span>
                <span style="color: #d4d4d4; flex: 1; word-break: break-word;">${escapeHtml(log.message)}</span>
              </div>
            </div>
          `;
        }).join('');
      } catch (e) {
        const logsContent = document.getElementById('logsContent');
        logsContent.innerHTML = `<div style="color: #ef4444; padding: 20px;">加载日志失败：${e.message}</div>`;
      }
    }
    
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    function refreshLogs() {
      loadLogs();
    }
    
    function copyLogs() {
      const logsContent = document.getElementById('logsContent');
      const text = logsContent.textContent;
      navigator.clipboard.writeText(text).then(() => {
        alert('日志已复制');
      }).catch(err => {
        alert('复制失败：' + err);
      });
    }
    
    // 重命名会话
    async function renameSession(sessionId) {
      const newName = prompt('请输入新会话名称:', sessionId);
      if (!newName || newName === sessionId) return;
      
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/rename`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ newName })
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        await loadProjectDetails();
      } catch (e) {
        alert('重命名失败：' + e.message);
      }
    }
    
    // 从对话界面重命名会话
    async function renameSessionFromConversation(sessionId) {
      const newName = prompt('请输入新会话名称:', sessionId);
      if (!newName || newName === sessionId) return;
      
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/rename`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ newName })
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        // 更新标题
        document.querySelector('.conversation-header-title h2').textContent = `💬 ${newName}`;
        await loadProjectDetails();
      } catch (e) {
        alert('重命名失败：' + e.message);
      }
    }
    
    // 查看记忆
    async function viewMemory(sessionId) {
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}/memory`);
        const data = await res.json();
        
        if (data.error) throw new Error(data.error);
        
        alert(`会话记忆:\n\n${data.content || '暂无内容'}`);
      } catch (e) {
        alert('查看记忆失败：' + e.message);
      }
    }
    
    // 删除会话
    async function deleteSession(sessionId) {
      if (!confirm(`确定删除会话 "${sessionId}"？\n\n这将删除该会话的所有记忆文件！`)) return;
      
      try {
        await fetch(`${API_BASE}/api/projects/${currentProject}/sessions/${sessionId}`, {
          method: 'DELETE'
        });
        await loadProjectDetails();
      } catch (e) {
        alert('删除会话失败：' + e.message);
      }
    }
    
    // 切换任务状态
    async function toggleTask(id) {
      try {
        await fetch(`${API_BASE}/api/projects/${currentProject}/tasks/${id}/toggle`, {
          method: 'POST'
        });
        await loadProjectDetails();
      } catch (e) {
        alert('切换任务状态失败：' + e.message);
      }
    }
    
    // 删除任务
    async function deleteTask(id) {
      if (!confirm('确定删除此任务？')) return;
      
      try {
        await fetch(`${API_BASE}/api/projects/${currentProject}/tasks/${id}`, {
          method: 'DELETE'
        });
        await loadProjectDetails();
      } catch (e) {
        alert('删除任务失败：' + e.message);
      }
    }
    
    // 编辑共享记忆
    async function editSharedMemory() {
      const currentContent = document.getElementById('sharedMemory').textContent;
      
      const modal = document.createElement('div');
      modal.className = 'modal-overlay active';
      modal.id = 'editSharedMemoryModal';
      modal.innerHTML = `
        <div class="modal" style="max-width: 700px;">
          <h2>✏️ 编辑共享记忆</h2>
          <div class="form-group">
            <label>记忆内容 (Markdown 格式)</label>
            <textarea id="editSharedMemoryContent" rows="15" style="width: 100%; font-family: monospace; font-size: 13px;">${currentContent}</textarea>
          </div>
          <div class="modal-actions">
            <button class="btn btn-secondary" onclick="document.getElementById('editSharedMemoryModal').remove()">取消</button>
            <button class="btn btn-primary" onclick="saveSharedMemory()">保存</button>
          </div>
        </div>
      `;
      document.body.appendChild(modal);
    }
    
    // 保存共享记忆
    async function saveSharedMemory() {
      const content = document.getElementById('editSharedMemoryContent').value;
      
      try {
        await fetch(`${API_BASE}/api/projects/${currentProject}/memory/shared`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content })
        });
        
        document.getElementById('editSharedMemoryModal').remove();
        renderMemory(content);
      } catch (e) {
        alert('保存失败：' + e.message);
      }
    }
    
    // 打开项目文件夹
    function openProjectFolder() {
      alert('请在终端中运行：\nopen ' + document.getElementById('infoPath').textContent);
    }
    
    // 导出项目
    async function exportProject() {
      if (!currentProject) return;
      
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/export`);
        const data = await res.json();
        
        if (data.error) throw new Error(data.error);
        
        const blob = new Blob([JSON.stringify(data.export, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${currentProject}-export-${new Date().toISOString().split('T')[0]}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      } catch (e) {
        alert('导出失败：' + e.message);
      }
    }
    
    // 重命名项目
    async function renameCurrentProject() {
      if (!currentProject) return;
      
      const newName = prompt('请输入新项目名称:', currentProject);
      if (!newName || newName === currentProject) return;
      
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}/rename`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ newName })
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        await loadProjects();
        renderProjectList();
        selectProject(newName);
      } catch (e) {
        alert('重命名失败：' + e.message);
      }
    }
    
    // 删除项目
    async function deleteCurrentProject() {
      if (!currentProject) return;
      
      if (!confirm(`⚠️  确定删除项目 "${currentProject}"？\n\n这将删除所有会话、任务和记忆数据！\n\n此操作不可恢复！`)) return;
      
      try {
        const res = await fetch(`${API_BASE}/api/projects/${currentProject}`, {
          method: 'DELETE'
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        currentProject = null;
        document.getElementById('noProjectSelected').style.display = 'block';
        document.getElementById('projectContent').style.display = 'none';
        document.getElementById('projectInfo').style.display = 'block';
        document.getElementById('projectInfoContent').style.display = 'none';
        
        await loadProjects();
        renderProjectList();
      } catch (e) {
        alert('删除项目失败：' + e.message);
      }
    }
    
    // 启动
    init();
  </script>
</body>
</html>
